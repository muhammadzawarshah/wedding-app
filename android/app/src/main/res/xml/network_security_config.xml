<?xml version="1.0" encoding="utf-8"?>
<!--
  Cleartext (http://) is permitted so the app can reach the shared dev backend
  (apps/api) on a LAN — e.g. a real phone hitting the dev machine at
  http://192.168.x.x:4000. Android's network security config can't express IP
  subnets, so cleartext is allowed app-wide for development convenience.

  Named dev hosts are listed explicitly too:
    - 10.0.2.2              : Android emulator's alias for the host machine
    - localhost / 127.0.0.1 : desktop / USB-forwarded devices

  For a production release, point API_BASE_URL at an https:// URL and set
  <base-config cleartextTrafficPermitted="false"> to forbid plain HTTP.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
